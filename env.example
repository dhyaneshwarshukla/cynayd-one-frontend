# Runtime (Cloud Run) — required on the frontend service, not baked into the image
API_URL=https://auth.cynayd.cloud
SITE_URL=https://one.cynayd.com

# Optional display name (can be set at build or runtime)
NEXT_PUBLIC_APP_NAME=CYNAYD One

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://one.cynayd.com

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Razorpay Payment Gateway (Frontend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id

# Local development
NODE_ENV=development
